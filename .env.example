# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# --- Database ---
# Local Docker Postgres (matches docker-compose.yml). Swap for Supabase/Neon/RDS later.
DATABASE_URL=postgresql://xmarket:xmarket@localhost:5432/xmarket

# --- Charles Schwab Trader API (price/market data) ---
# Register an app at https://developer.schwab.com to get these.
SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=
# Must exactly match the callback URL set on your Schwab app (https required).
SCHWAB_CALLBACK_URL=https://127.0.0.1:8182
# Where the saved OAuth token (access + refresh) is cached. Keep this out of git.
SCHWAB_TOKEN_PATH=.schwab_token.json

# --- X (Twitter) API v2 ---
# App-only bearer token: public recent search.
X_BEARER_TOKEN=
# OAuth 2.0 user auth: your reverse-chronological following feed.
X_CLIENT_ID=
X_CLIENT_SECRET=
# Must exactly match the OAuth 2.0 redirect URI in the X developer portal.
X_REDIRECT_URI=http://127.0.0.1:8001/x/callback
# Local OAuth token cache. This file is created by `uv run xmarket x-login`.
X_USER_TOKEN_PATH=.x_user_token.json

# --- Anthropic (Claude Haiku enrichment) ---
ANTHROPIC_API_KEY=
QUALIFY_MODEL=claude-haiku-4-5
SENTIMENT_MODEL=claude-haiku-4-5
QUALIFY_PROMPT_VERSION=qualify-v1
TICKER_PROMPT_VERSION=ticker-v1
SENTIMENT_PROMPT_VERSION=sentiment-v1
ENRICHMENT_PRICE_DAYS=30

# --- Application ---
# Comma-separated tickers to track.
WATCHLIST=AAPL,TSLA,NVDA,MSFT,AMZN

# Comma-separated API keys that may call the FastAPI write/job endpoints.
API_KEYS=dev-local-key

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
